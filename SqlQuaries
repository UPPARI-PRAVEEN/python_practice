Get all customers from USA.

select * from Customers
where country = "USA";

age is greater than 25.
select * from Customers
where age > 25;

Get customer name + their orders (item, amount).

select c.first_name,o.item,o.amount from 
Customers c JOIN Orders o
on c.customer_id = o.customer_id

find customers who have not made any orders.
select c.first_name,o.item,o.amount,count(*) from 
Customers c JOIN Orders o
on c.customer_id = o.customer_id
where o.customer_id is null;

hanving shipping status
select c.*,s.* from 
Customers c JOIN Shippings s
on c.customer_id = s.customer;


Find total amount spent by each customer.
select c.*,o.*,avg(o.amount) AS "Sum_Amount" from 
Customers c JOIN Orders o
on c.customer_id = o.customer_id
group by c.customer_id, c.first_name;

having total amount greater than 500 for each customer.
select c.*,o.*,sum(o.amount) as "Amount" from 
Customers c JOIN Orders o
on c.customer_id = o.customer_id
group by c.customer_id
having sum(o.amount) > 500;

having more than 1 order for each country.
select c.*,o.* from 
Customers c JOIN Orders o
on c.customer_id = o.customer_id
group by c.country
having count(c.country) > 1;


top 2 customers with highest amount spent.
select *
from (select c.first_name,o.amount,sum(o.amount) as "SUM AMOUNT", RANK() OVER (ORDER by sum(o.amount) desc) as rnk
from Customers c LEFT JOIN Orders o ON c.customer_id = o.customer_id
group by c.customer_id
     ) t
where rnk <=2;

second highest amount spent by customer.

select c.first_name,o.amount 
from Customers c LEFT JOIN Orders o
on c.customer_id = o.customer_id
where o.amount = (select MAX(amount) from Orders
where amount < (select max(amount) from Orders));


having  customer with same age.
select c.first_name 
from Customers c  JOIN Customers o
on c.customer_id = o.customer_id
where c.age IN (select age from Customers
                group by age
having count(*) > 1

);

Ranking customers based on total amount spent.
select *
from (select c.*,o.*,SUM(o.amount) AS "total amount", RANK() OVER (Order by SUM(o.amount) DESC) as rnk  from Customers c JOIN Orders o ON c.customer_id = o.customer_id 
group by c.customer_id,c.first_name
) t











